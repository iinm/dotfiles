{
  "autoApproval": {
    "defaultAction": "ask",
    "maxApprovals": 100,
    "patterns": [
      {
        "toolName": "exec_command",
        "input": {
          "command": "git",
          "args": [{ "$regex": "^(status|diff|log|show|ls-remote|rev-parse)$" }]
        },
        "action": "allow"
      },
      {
        "toolName": "exec_command",
        "input": { "command": { "$regex": "^(git|gh|docker)$" } },
        "action": "ask"
      },
      {
        "toolName": { "$regex": "^(write_file|patch_file)$" },
        "action": "allow"
      },
      {
        "toolName": { "$regex": "^(web_search|web_fetch)$" },
        "action": "allow"
      },
      {
        "toolName": "exec_command",
        "action": "allow"
      }
    ]
  },
  "sandbox": {
    "command": "plain-sandbox",
    "args": [
      "--allow-write",
      "--mount-readonly", ".plain-agent/config.json,.plain-agent/config.sandbox.json",
      "--keep-alive", "30"
    ],
    "separator": "--",
    "rules": [
      {
        "pattern": { "command": { "$regex": "^(git|gh|docker)$" } },
        "mode": "unsandboxed"
      }
    ]
  }
}
