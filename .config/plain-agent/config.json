{
  "autoApproval": {
    "defaultAction": "ask",
    "maxApprovals": 100,
    "patterns": [
      {
        "toolName": { "$regex": "^(write_file|patch_file)$" },
        "action": "allow"
      },
      {
        "toolName": { "$regex": "^(web_search|web_fetch)$" },
        "action": "allow"
      }
    ]
  },

  "claudeCodePlugins": [
    {
      "source": "https://github.com/anthropics/claude-code",
      "plugins": [
        { "name": "feature-dev", "path": "plugins/feature-dev" },
        { "name": "code-review", "path": "plugins/code-review" },
        { "name": "pr-review-toolkit", "path": "plugins/pr-review-toolkit" }
      ]
    },
    {
      "source": "https://github.com/anthropics/claude-code-security-review",
      "plugins": [
        { "name": "security-review", "path": ".claude" }
      ]
    }
  ]
}
